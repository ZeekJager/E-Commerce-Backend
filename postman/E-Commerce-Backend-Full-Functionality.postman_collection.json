  "item": [
    {
      "name": "Products",
      "item": [
        {
          "name": "Create Product A — Laptop",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Location header present', () => pm.expect(pm.response.headers.get('Location')).to.include('/api/products/'));",
                  "const j = pm.response.json();",
                  "pm.test('Response has product fields', () => {",
                  "  pm.expect(j.id).to.be.a('string');",
                  "  pm.expect(j.name).to.eql('ProBook Laptop 15');",
                  "  pm.expect(j.price).to.eql(1299.99);",
                  "  pm.expect(j.stock).to.eql(50);",
                  "});",
                  "pm.collectionVariables.set('productAId', j.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key",    "value": "{{apiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"ProBook Laptop 15\",\n  \"category\": \"electronics\",\n  \"price\": 1299.99,\n  \"stock\": 50\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/products", "host": ["{{baseUrl}}"], "path": ["api","products"] }
          }
        },

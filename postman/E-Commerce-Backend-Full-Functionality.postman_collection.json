      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Location header present', () => pm.expect(pm.response.headers.get('Location')).to.include('/api/orders/'));",
                  "const j = pm.response.json();",
                  "pm.test('Order fields present', () => {",
                  "  pm.expect(j.id).to.be.a('string');",
                  "  pm.expect(j.customerId).to.eql('cust-7341');",
                  "  pm.expect(j.productIds).to.be.an('array').with.lengthOf(2);",
                  "  pm.expect(j.totalAmount).to.be.a('number').and.gt(0);",
                  "  pm.expect(j.shippingAddress).to.include('742 Evergreen Terrace');",
                  "});",
                  "pm.collectionVariables.set('orderId', j.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key",    "value": "{{apiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"cust-7341\",\n  \"productIds\": [\n    \"{{productAId}}\",\n    \"{{productBId}}\"\n  ],\n  \"shippingAddress\": {\n    \"street\": \"742 Evergreen Terrace\",\n    \"city\": \"Springfield\",\n    \"zipCode\": \"62701\",\n    \"country\": \"US\"\n  }\n}"
            },

              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('ID matches', () => pm.expect(j.id).to.eql(pm.collectionVariables.get('orderId')));",

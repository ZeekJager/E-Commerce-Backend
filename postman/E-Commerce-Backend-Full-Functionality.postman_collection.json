        {
          "name": "409 — Create Order for out-of-stock product",
          "event": [
            {
              "listen": "pre-request",
              "script": {
                "exec": [
                  "// First create a product with stock=0, save its ID for this test",
                  "pm.sendRequest({",
                  "  url: pm.collectionVariables.get('baseUrl') + '/api/products',",
                  "  method: 'POST',",
                  "  header: { 'Content-Type': 'application/json', 'X-API-Key': pm.collectionVariables.get('apiKey') },",
                  "  body: { mode: 'raw', raw: JSON.stringify({ name: 'Sold Out Widget', category: 'test', price: 1.00, stock: 0 }) }",
                  "}, (err, res) => {",
                  "  pm.collectionVariables.set('outOfStockId', res.json().id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('409 Conflict', () => pm.response.to.have.status(409));",
                  "const j = pm.response.json();",
                  "pm.test('Error mentions out of stock', () => pm.expect(j.error).to.include('out of stock'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key",    "value": "{{apiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"cust-unlucky\",\n  \"productIds\": [\"{{outOfStockId}}\"],\n  \"shippingAddress\": {\n    \"street\": \"99 Retry Road\",\n    \"city\": \"Backorderburg\",\n    \"zipCode\": \"10001\",\n    \"country\": \"US\"\n  }\n}"
            },
